/* ===== Reset & Base ===== */
*, *::before, *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  font-size: 16px;
}

body {
  font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
  min-height: 100vh;
  background: linear-gradient(135deg, #09090e, #14112e, #1a1a2e);
  color: #e0e0e0;
  overflow-x: hidden;
}

/* ===== Animated Background Shapes ===== */
.bg-shapes {
  position: fixed;
  inset: 0;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}

.shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.35;
  animation: float 25s ease-in-out infinite;
}

.shape-1 { width: 500px; height: 500px; background: #7f5af0; top: -100px; left: -100px; }
.shape-2 { width: 400px; height: 400px; background: #2cb67d; bottom: -60px; right: -60px; animation-delay: -7s; }
.shape-3 { width: 350px; height: 350px; background: #e53170; top: 40%; left: 50%; transform: translateX(-50%); animation-delay: -14s; }

@media (max-width: 768px) {
  .shape-1 { width: 300px; height: 300px; top: -80px; left: 50%; transform: translateX(-70%); }
  .shape-2 { width: 250px; height: 250px; bottom: 10%; right: -40px; }
  .shape-3 { width: 200px; height: 200px; top: 50%; left: 50%; transform: translate(-50%, -50%); }
}

@keyframes float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25%      { transform: translate(5vw, -5vw) scale(1.05); }
  50%      { transform: translate(-3vw, 4vw) scale(0.95); }
  75%      { transform: translate(4vw, 2vw) scale(1.02); }
}

/* ===== Full Page Layouts ===== */
.page-wrapper {
  position: relative;
  z-index: 1;
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Auth specific fullscreen */
.auth-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 20px;
}

.auth-box {
  width: 100%;
  max-width: 480px;
  background: rgba(20, 20, 30, 0.4);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 28px;
  padding: 48px 40px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* Dashboard Top Nav */
.top-nav {
  width: 100%;
  padding: 16px 40px;
  background: rgba(10, 10, 15, 0.5);
  backdrop-filter: blur(25px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 50;
  animation: slideInNav 0.5s ease forwards;
  flex-wrap: wrap;
  gap: 12px;
}

.nav-brand h1 {
  font-size: 1.6rem;
  font-weight: 800;
  background: linear-gradient(to right, #7f5af0, #2cb67d);
  -webkit-background-clip: text;
  color: transparent;
  letter-spacing: -0.5px;
}

.nav-user {
  display: flex;
  align-items: center;
  gap: 16px;
}

.nav-user p {
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.7);
}

.nav-actions {
  display: flex;
  gap: 12px;
}

/* ===== Dashboard Sub-Navigation (Tabs) ===== */
.dash-tabs {
  display: flex;
  gap: 0;
  padding: 0 40px;
  background: rgba(0, 0, 0, 0.15);
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  overflow-x: auto;
}

.dash-tab {
  padding: 16px 28px;
  background: none;
  border: none;
  border-bottom: 3px solid transparent;
  color: rgba(255, 255, 255, 0.4);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s;
  white-space: nowrap;
  position: relative;
}

.dash-tab:hover {
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.03);
}

.dash-tab.active {
  color: #fff;
  border-bottom-color: #7f5af0;
}

.dash-tab .tab-badge {
  display: inline-block;
  background: rgba(127, 90, 240, 0.3);
  color: #b49af0;
  font-size: 0.7rem;
  padding: 2px 8px;
  border-radius: 10px;
  margin-left: 8px;
  font-weight: 700;
}

.dash-tab-content {
  display: none;
  animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.dash-tab-content.active {
  display: block;
}

@media (max-width: 768px) {
  .dash-tabs { padding: 0 16px; }
  .dash-tab { padding: 14px 20px; font-size: 0.85rem; }
}

/* Main Content Area */
.main-content {
  flex: 1;
  padding: 40px;
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@media (min-width: 1024px) {
  .grid-layout {
    grid-template-columns: 320px 1fr;
    align-items: start;
  }
}

/* Content Blocks (replacing old cards inside container) */
.content-block {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px;
  padding: 32px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.2);
  transition: transform 0.3s ease, background 0.3s ease;
}
.content-block:hover {
  background: rgba(255, 255, 255, 0.04);
}

/* ===== Typography & Headers ===== */
h2, h3 { font-weight: 600; letter-spacing: -0.3px; }
.card-header { text-align: center; margin-bottom: 32px; }
.card-header h1 { font-size: 2rem; color: #fff; margin-bottom: 8px; font-weight: 800; letter-spacing: -0.5px; }
.card-header p { font-size: 1rem; color: rgba(255, 255, 255, 0.5); }
.section-title { font-size: 1.1rem; color: #fff; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 12px; }

/* ===== Animations ===== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes slideInNav {
  from { opacity: 0; transform: translateY(-100%); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ===== Tabs ===== */
.tabs {
  display: flex;
  gap: 6px;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 14px;
  padding: 6px;
  margin-bottom: 32px;
}

.tab {
  flex: 1;
  padding: 12px 0;
  border: none;
  border-radius: 10px;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  background: transparent;
  color: rgba(255, 255, 255, 0.4);
  transition: all 0.3s ease;
}

.tab.active { background: #7f5af0; color: #fff; box-shadow: 0 4px 15px rgba(127, 90, 240, 0.4); }
.tab:hover:not(.active) { color: rgba(255, 255, 255, 0.8); background: rgba(255,255,255,0.05); }

/* ===== Forms & Inputs ===== */
.form { display: none; flex-direction: column; gap: 20px; }
.form.active { display: flex; animation: fadeUp 0.4s ease; }
.input-group { position: relative; }
.input-icon { position: absolute; left: 18px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; pointer-events: none; opacity: 0.6; }

.input-group input {
  width: 100%;
  padding: 16px 20px 16px 54px;
  background: rgba(0, 0, 0, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 16px;
  font-size: 1rem;
  color: #fff;
  outline: none;
  transition: all 0.3s;
}

.input-group input::placeholder { color: rgba(255, 255, 255, 0.3); }
.input-group input:focus { border-color: #7f5af0; box-shadow: 0 0 0 4px rgba(127, 90, 240, 0.15); background: rgba(0,0,0,0.4); }

.form-actions { display: flex; gap: 12px; }
.form-actions .btn { flex: 1; }

/* ===== Buttons ===== */
.btn {
  padding: 16px 24px;
  border: none;
  border-radius: 14px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.btn-sm { padding: 10px 18px; font-size: 0.9rem; }

.btn-primary { background: linear-gradient(135deg, #7f5af0, #5c35cf); color: #fff; box-shadow: 0 8px 24px rgba(127, 90, 240, 0.3); }
.btn-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(127, 90, 240, 0.5); }
.btn-primary:active { transform: translateY(0); }

.btn-secondary { background: linear-gradient(135deg, #2cb67d, #1a8f5f); color: #fff; box-shadow: 0 8px 24px rgba(44, 182, 125, 0.25); }
.btn-secondary:hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(44, 182, 125, 0.45); }

.btn-outline { background: transparent; color: rgba(255, 255, 255, 0.7); border: 1px solid rgba(255, 255, 255, 0.2); }
.btn-outline:hover { background: rgba(255, 255, 255, 0.08); color: #fff; transform: translateY(-2px); }

.btn-danger { background: linear-gradient(135deg, #e53170, #c22558); color: #fff; }

.icon-btn {
  width: 44px; height: 44px;
  border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.03); color: rgba(255, 255, 255, 0.7);
  font-size: 1.2rem; cursor: pointer; transition: all 0.2s;
  display: flex; align-items: center; justify-content: center;
}
.icon-btn:hover { background: rgba(255, 255, 255, 0.1); color: #fff; transform: translateY(-2px); }

.fab {
  width: 48px; height: 48px; border-radius: 50%; border: none;
  background: linear-gradient(135deg, #7f5af0, #6c3ed6); color: #fff; font-size: 1.6rem;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8px 24px rgba(127, 90, 240, 0.4); transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.fab:hover { transform: translateY(-4px) scale(1.05); box-shadow: 0 12px 30px rgba(127, 90, 240, 0.6); }
.fab-sm { width: 36px; height: 36px; font-size: 1.2rem; }

/* ===== Links ===== */
.link-text { text-align: center; font-size: 0.9rem; color: rgba(255, 255, 255, 0.5); }
.link-text a { color: #7f5af0; text-decoration: none; font-weight: 600; }
.link-text a:hover { text-decoration: underline; }

/* ===== Messages ===== */
.message { padding: 14px 20px; border-radius: 12px; font-size: 0.9rem; text-align: center; animation: fadeUp 0.3s ease; }
.message.success { background: rgba(44, 182, 125, 0.15); color: #2cb67d; border: 1px solid rgba(44, 182, 125, 0.3); }
.message.error { background: rgba(229, 49, 112, 0.15); color: #e53170; border: 1px solid rgba(229, 49, 112, 0.3); }
.admin-msg { padding: 12px; border-radius: 12px; font-size: 0.9rem; text-align: center; display: none; }
.admin-msg.error { display: block; background: rgba(229,49,112,0.15); color: #e53170; border: 1px solid rgba(229,49,112,0.3); }
.admin-msg.success { display: block; background: rgba(44,182,125,0.15); color: #2cb67d; border: 1px solid rgba(44,182,125,0.3); }

/* ===== Settings Panel Elements ===== */
.info-row { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
.info-label { font-size: 0.9rem; color: rgba(255, 255, 255, 0.5); }
.info-value { font-size: 0.95rem; color: #fff; font-weight: 600; }
.highlight { color: #7f5af0; font-weight: 700; }
.role-badge { text-transform: capitalize; padding: 4px 12px; background: rgba(255,255,255,0.1); border-radius: 20px; font-size: 0.8rem; }

/* ===== Custom Layout for Links & Mgmt ===== */
.links-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
.links-header h2 { font-size: 1.4rem; color: #fff; font-weight: 700; display: flex; align-items: center;}
.links-header-actions { display: flex; align-items: center; gap: 12px; }

/* Search Bar */
.search-bar { position: relative; display: flex; align-items: center; margin-bottom: 24px; }
.search-icon { position: absolute; left: 16px; font-size: 1.1rem; opacity: 0.5; pointer-events: none; }
.search-bar input { width: 100%; padding: 14px 44px 14px 44px; background: rgba(0, 0, 0, 0.2); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 14px; color: #fff; font-size: 0.95rem; outline: none; transition: all 0.3s; }
.search-bar input:focus { border-color: #7f5af0; background: rgba(0, 0, 0, 0.4); box-shadow: 0 0 0 3px rgba(127,90,240,0.15); }
.search-bar input::placeholder { color: rgba(255, 255, 255, 0.3); }
.search-clear { position: absolute; right: 12px; background: none; border: none; color: rgba(255, 255, 255, 0.4); font-size: 1.4rem; cursor: pointer; padding: 4px 8px; transition: color 0.2s; }
.search-clear:hover { color: #fff; }

.create-link-panel { background: rgba(127, 90, 240, 0.05); border: 1px solid rgba(127, 90, 240, 0.2); border-radius: 20px; padding: 24px; margin-bottom: 24px; animation: fadeUp 0.4s ease; }
.form-panel-title { font-size: 1.1rem; color: #b49af0; margin-bottom: 16px; font-weight: 600; }

/* Toggles & Schedules */
.schedule-toggle { margin-bottom: 16px; }
.toggle-label { display: flex; align-items: center; gap: 10px; cursor: pointer; font-size: 0.95rem; color: rgba(255, 255, 255, 0.7); }
.toggle-label input[type="checkbox"] { accent-color: #7f5af0; width: 18px; height: 18px; cursor: pointer; }
.schedule-builder { background: rgba(0, 0, 0, 0.2); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 20px; margin-bottom: 20px; animation: fadeUp 0.3s ease; }
.timezone-selector { display: flex; gap: 12px; margin-bottom: 16px; }
.tz-option { display: flex; align-items: center; gap: 8px; cursor: pointer; flex: 1; background: rgba(255, 255, 255, 0.03); padding: 12px 16px; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.05); transition: all 0.2s; }
.tz-option:has(input:checked) { background: rgba(127, 90, 240, 0.15); border-color: rgba(127, 90, 240, 0.4); }
.tz-option input { accent-color: #7f5af0; width: 16px; height: 16px; }
.tz-label { font-size: 0.9rem; color: rgba(255, 255, 255, 0.8); }
.schedule-days { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
.delete-auth-toggle { display: inline-flex; align-items: center; gap: 4px; font-size: 0.85rem; color: rgba(255,255,255,0.7); cursor: pointer; white-space: nowrap; }
.delete-auth-toggle input { accent-color: #7f5af0; width: 14px; height: 14px; margin: 0; padding: 0; flex-shrink: 0; }
.delete-auth-toggle span { margin: 0; padding: 0; }
.day-check { display: flex; align-items: center; gap: 6px; font-size: 0.85rem; color: rgba(255, 255, 255, 0.6); background: rgba(255, 255, 255, 0.04); padding: 8px 14px; border-radius: 10px; cursor: pointer; transition: all 0.2s; }
.day-check:has(input:checked) { background: rgba(127, 90, 240, 0.2); color: #fff; border: 1px solid rgba(127,90,240,0.3); }
.day-check input { accent-color: #7f5af0; width: 15px; height: 15px; }
.schedule-time-row { display: flex; align-items: center; gap: 12px; }
.input-sm { flex: 1; padding: 12px 16px; }
.time-sep { color: rgba(255,255,255,0.4); }

/* Link Cards */
.links-list { display: flex; flex-direction: column; gap: 16px; }
.link-card { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 20px; padding: 24px; display: flex; justify-content: space-between; align-items: center; transition: all 0.3s; }
.link-card:hover { background: rgba(255, 255, 255, 0.05); border-color: rgba(255, 255, 255, 0.1); transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
.link-card-info { flex: 1; min-width: 0; }
.link-card-info h3 { font-size: 1.1rem; color: #fff; margin-bottom: 6px; }
.link-card-url { font-size: 0.85rem; color: #b49af0; font-family: monospace; }
.link-card-actions { display: flex; gap: 8px; margin-left: 16px; flex-shrink: 0; }
.link-action-btn { width: 40px; height: 40px; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.08); background: rgba(255, 255, 255, 0.03); color: rgba(255, 255, 255, 0.7); font-size: 1rem; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; }
.link-action-btn:hover { background: rgba(255, 255, 255, 0.1); color: #fff; transform: translateY(-2px); }
.link-action-btn.copy-btn:hover { background: rgba(44, 182, 125, 0.2); color: #2cb67d; }
.link-action-btn.edit-btn:hover { background: rgba(255, 193, 7, 0.2); color: #ffd54f; }
.link-action-btn.delete-btn:hover { background: rgba(229, 49, 112, 0.2); color: #e53170; }

.link-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
.link-badge { padding: 4px 10px; border-radius: 8px; font-size: 0.75rem; font-weight: 600; display: inline-flex; align-items: center; }
.schedule-badge { background: rgba(127, 90, 240, 0.15); color: #b49af0; border: 1px solid rgba(127, 90, 240, 0.2); }
.expiry-badge { background: rgba(44, 182, 125, 0.15); color: #6ed4a8; border: 1px solid rgba(44, 182, 125, 0.2); }

/* Mgmt Lists */
.mgmt-section { margin-top: 32px; padding-top: 32px; border-top: 1px solid rgba(255, 255, 255, 0.05); }
.mgmt-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.mgmt-list { display: flex; flex-direction: column; gap: 12px; }
.mgmt-link-card { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 20px; transition: all 0.3s; }
.mgmt-link-card:hover { transform: translateY(-2px); background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1); box-shadow: 0 8px 20px rgba(0,0,0,0.2); }
.mgmt-link-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; gap: 10px; }
.mgmt-link-username { font-size: 1.05rem; font-weight: 700; color: #fff; flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.mgmt-link-status { padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; border: 1px solid transparent; }
.mgmt-link-status.active { background: rgba(44, 182, 125, 0.15); color: #2cb67d; border-color: rgba(44, 182, 125, 0.3); }
.mgmt-link-status.paused { background: rgba(255, 193, 7, 0.12); color: #ffd54f; border-color: rgba(255, 193, 7, 0.25); }
.mgmt-link-status.joined { background: rgba(127, 90, 240, 0.15); color: #b49af0; border-color: rgba(127, 90, 240, 0.25); }
.mgmt-link-details { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
.mgmt-link-detail { font-size: 0.85rem; color: rgba(255, 255, 255, 0.5); }
.mgmt-link-detail strong { color: rgba(255, 255, 255, 0.8); }
.mgmt-link-url { font-size: 0.85rem; color: #b49af0; font-family: monospace; word-break: break-all; white-space: normal; }
.mgmt-action-btn { padding: 6px 14px; border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.03); color: rgba(255, 255, 255, 0.7); font-size: 0.8rem; cursor: pointer; transition: all 0.2s; font-weight: 600; }
.mgmt-action-btn:hover { background: rgba(255, 255, 255, 0.1); color: #fff; transform: translateY(-1px); }
.mgmt-action-btn.copy-btn:hover { background: rgba(44, 182, 125, 0.2); color: #2cb67d; border-color: rgba(44, 182, 125, 0.4); }
.mgmt-action-btn.delete-btn:hover { background: rgba(229, 49, 112, 0.2); color: #e53170; border-color: rgba(229, 49, 112, 0.4); }
.mgmt-action-btn.pause-btn:hover { background: rgba(255, 193, 7, 0.2); color: #ffd54f; border-color: rgba(255, 193, 7, 0.4); }

.empty-state { text-align: center; color: rgba(255, 255, 255, 0.3); padding: 40px; font-size: 0.95rem; }
.load-more-btn { width: 100%; margin-top: 16px; border-radius: 12px; padding: 12px; }

/* Admin Panels (Overrides/Additions for admin.html) */
.admin-badge { padding: 4px 12px; border-radius: 12px; font-size: 0.8rem; font-weight: 600; white-space: nowrap; }
.badge-ready { background: rgba(127,90,240,0.2); color: #b49af0; }
.badge-connected { background: rgba(44,182,125,0.2); color: #6ed4a8; }
.badge-blocked { background: rgba(229,49,112,0.2); color: #e53170; }

.btn-block { padding: 6px 14px; font-size: 0.8rem; border-radius: 10px; cursor: pointer; border: none; font-weight: 600; transition: all 0.2s; }
.btn-block.block { background: rgba(229,49,112,0.2); color: #e53170; }
.btn-block.block:hover { background: rgba(229,49,112,0.4); transform: translateY(-1px); }
.btn-block.unblock { background: rgba(44,182,125,0.2); color: #2cb67d; }
.btn-block.unblock:hover { background: rgba(44,182,125,0.4); transform: translateY(-1px); }

.generate-row { display: flex; justify-content: center; margin-bottom: 32px; animation: fadeUp 0.3s ease; }
.generate-form { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; background: rgba(255,255,255,0.03); padding: 20px 24px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.05); }
.generate-form input { padding: 14px 20px; border-radius: 14px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: #fff; font-size: 0.95rem; outline: none; width: 240px; }
.generate-form input:focus { border-color: #7f5af0; box-shadow: 0 0 0 3px rgba(127,90,240,0.15); }

.code-list { display: flex; flex-direction: column; gap: 16px; }
.code-item { display: flex; flex-direction: column; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; padding: 20px 24px; transition: transform 0.3s, background 0.3s; }
.code-item:hover { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
.code-item-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
.code-info { display: flex; flex-direction: column; gap: 8px; flex: 1; }
.code-value { font-family: monospace; font-size: 1.1rem; color: #b49af0; font-weight: 600; cursor: pointer; transition: color 0.2s; }
.code-value:hover { color: #fff; }
.code-meta { font-size: 0.85rem; color: rgba(255,255,255,0.4); }
.code-actions { display: flex; align-items: center; gap: 12px; }
.btn-details { background: rgba(127,90,240,0.15); color: #b49af0; border: none; padding: 6px 14px; border-radius: 10px; cursor: pointer; font-weight: 600; transition: all 0.2s; font-size: 0.85rem; }
.btn-details:hover { background: rgba(127,90,240,0.3); transform: translateY(-1px); }

.code-details-pane { padding-top: 16px; margin-top: 16px; border-top: 1px solid rgba(255,255,255,0.05); display: none; animation: fadeUp 0.3s ease; }
.code-details-pane.active { display: block; }
.user-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: rgba(0,0,0,0.2); border-radius: 12px; margin-bottom: 8px; transition: background 0.2s; border: 1px solid transparent; }
.user-row:hover { background: rgba(0,0,0,0.3); border-color: rgba(255,255,255,0.05); }
.hierarchy-title { font-size: 0.9rem; color: #b49af0; font-weight: 600; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 0.5px; }
.user-row.indent-1 { margin-left: 24px; border-left: 3px solid #7f5af0; }
.user-row.indent-2 { margin-left: 48px; border-left: 3px solid #2cb67d; }

.btn-temp-login { background: rgba(44,182,125,0.15); color: #2cb67d; border: 1px solid rgba(44,182,125,0.2); border-radius: 8px; padding: 4px 12px; font-size: 0.8rem; cursor: pointer; font-weight: 600; transition: all 0.2s; }
.btn-temp-login:hover { background: rgba(44,182,125,0.3); color: #fff; transform: translateY(-1px); }
.name-edit-row { display: flex; gap: 8px; margin-top: 6px; }
.name-edit-row input { padding: 6px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: #fff; font-size: 0.8rem; width: 180px; }
.name-edit-row input:focus { border-color: #7f5af0; }
.btn-name { background: rgba(127,90,240,0.15); color: #b49af0; border: none; padding: 6px 12px; border-radius: 8px; cursor: pointer; font-size: 0.8rem; font-weight: 600; transition: all 0.2s; }
.btn-name:hover { background: rgba(127,90,240,0.3); }

/* Copy Toast */
.copy-toast { position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%) translateY(20px); background: #2cb67d; color: #fff; padding: 12px 24px; border-radius: 30px; font-size: 0.95rem; font-weight: 600; opacity: 0; pointer-events: none; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); z-index: 1000; box-shadow: 0 10px 30px rgba(44,182,125,0.4); }
.copy-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* Call/Chat Integrations unmodified */
.call-overlay, .incoming-call-popup, .chat-card { border-radius: 24px; }
.call-overlay { position: absolute; inset: 0; background: rgba(10, 10, 15, 0.95); backdrop-filter: blur(20px); display: flex; align-items: center; justify-content: center; z-index: 100; animation: fadeIn 0.4s ease; }
#incoming-calls-container { position: fixed; inset: 0; pointer-events: none; z-index: 200; }
.incoming-call-popup { position: absolute; inset: 0; background: rgba(10, 10, 15, 0.95); backdrop-filter: blur(20px); display: flex; align-items: center; justify-content: center; pointer-events: auto; animation: fadeIn 0.3s ease; }
.call-overlay-content { text-align: center; }
.call-pulse { width: 100px; height: 100px; border-radius: 50%; background: rgba(44, 182, 125, 0.3); margin: 0 auto 24px; animation: pulse 1.5s ease-in-out infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); opacity: 0.6; } 50% { transform: scale(1.3); opacity: 0.2; } }
.call-actions { display: flex; gap: 20px; justify-content: center; margin-top: 32px; }
.call-btn { padding: 16px 36px; border: none; border-radius: 50px; font-size: 1.05rem; font-weight: 600; cursor: pointer; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
.call-btn.accept { background: linear-gradient(135deg, #2cb67d, #1e9e6b); color: #fff; box-shadow: 0 8px 24px rgba(44, 182, 125, 0.4); }
.call-btn.accept:hover { transform: scale(1.08); box-shadow: 0 12px 30px rgba(44, 182, 125, 0.5); }
.call-btn.decline { background: linear-gradient(135deg, #e53170, #c22558); color: #fff; box-shadow: 0 8px 24px rgba(229, 49, 112, 0.4); }
.call-btn.decline:hover { transform: scale(1.08); box-shadow: 0 12px 30px rgba(229, 49, 112, 0.5); }

/* Chat Card specific resets */
.chat-card { background: rgba(20, 20, 30, 0.9); border: 1px solid rgba(255,255,255,0.05); padding: 0; display: flex; flex-direction: column; overflow: hidden; }
.chat-header { padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; gap: 16px; }
.chat-messages { padding: 20px; flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; }
.chat-bubble { padding: 12px 18px; border-radius: 20px; font-size: 0.95rem; }
.chat-msg-sent .chat-bubble { background: #7f5af0; color: #fff; border-bottom-right-radius: 4px; }
.chat-msg-received .chat-bubble { background: rgba(255,255,255,0.08); border-bottom-left-radius: 4px; }
.chat-input-bar { padding: 16px 20px; background: rgba(0,0,0,0.2); border-top: 1px solid rgba(255,255,255,0.05); display: flex; gap: 12px; }
.chat-input-bar input { flex: 1; padding: 14px 20px; border-radius: 30px; background: rgba(255,255,255,0.05); border: 1px solid transparent; color: #fff; transition: all 0.2s; }
.chat-input-bar input:focus { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.1); }
.chat-input-btn { width: 44px; height: 44px; border-radius: 50%; opacity: 0.8; transition: all 0.2s; background: rgba(255,255,255,0.05); border: none; color: #fff; }
.chat-input-btn:hover { opacity: 1; background: rgba(255,255,255,0.1); transform: scale(1.05); }
.chat-input-btn.chat-send { background: #7f5af0; }

.hidden { display: none !important; }

/* ===== Stagger Animation for Lists ===== */
.content-block { animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; }
.content-block:nth-child(2) { animation-delay: 0.1s; }
.content-block:nth-child(3) { animation-delay: 0.15s; }

/* ===== Generate Form Polish ===== */
.generate-form { justify-content: flex-start; }
.generate-form input::placeholder { color: rgba(255,255,255,0.3); }

/* Responsive Adjustments */
@media (max-width: 768px) {
  .top-nav { padding: 14px 20px; }
  .nav-user p { font-size: 0.85rem; }
  .main-content { padding: 16px; gap: 20px; }
  .content-block { padding: 20px; border-radius: 16px; }
  .card-header h1 { font-size: 1.6rem; }
  .auth-box { padding: 32px 20px; border-radius: 20px; }
  .link-card { flex-direction: column; align-items: flex-start; gap: 16px; }
  .link-card-actions { margin-left: 0; width: 100%; justify-content: flex-start; }
  .links-header h2 { font-size: 1.15rem; }
  .generate-form { flex-direction: column; align-items: stretch; }
  .generate-form input { width: 100%; }
  .generate-form .btn { width: 100%; }
}
